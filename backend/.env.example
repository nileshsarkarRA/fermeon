# ── Server-side API Keys (optional defaults — users can override per-request) ──
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...

# ── Ollama (local LLMs) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── CAD Execution ────────────────────────────────────────────────────────────
CADQUERY_TIMEOUT_SECONDS=30
MAX_CORRECTION_ATTEMPTS=3
ENABLE_FALLBACK=true
DEFAULT_MODEL=gemini/gemini-2.0-flash

# ── Application ──────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
OUTPUT_DIR=./outputs
DEBUG=false

# ── Storage (optional — leave empty to use local file storage) ───────────────
USE_S3=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=fermeon-cad-files
